  <script>
  (function () {

    /* ---- Reading progress bar ---- */
    var bar = document.getElementById('bdReadBar');
    function updateProgress() {
      var scrollTop = window.scrollY || document.documentElement.scrollTop;
      var docHeight = document.documentElement.scrollHeight - window.innerHeight;
      var pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      if (bar) bar.style.width = Math.min(pct, 100) + '%';
    }
    window.addEventListener('scroll', updateProgress, { passive: true });

    /* ---- Floating share bar visibility ---- */
    var shareFloat = document.getElementById('bdShareFloat');
    function toggleShareBar() {
      if (!shareFloat) return;
      var hero = document.querySelector('.bd-hero');
      var heroH = hero ? hero.offsetHeight : 300;
      if (window.scrollY > heroH) {
        shareFloat.classList.add('bd-share-float--visible');
      } else {
        shareFloat.classList.remove('bd-share-float--visible');
      }
    }
    window.addEventListener('scroll', toggleShareBar, { passive: true });

    /* ---- TOC toggle ---- */
    var tocToggle = document.getElementById('bdTocToggle');
    var tocList = document.getElementById('bdTocList');
    if (tocToggle && tocList) {
      tocToggle.addEventListener('click', function () {
        var isOpen = !tocList.classList.contains('bd-toc-list--collapsed');
        tocList.classList.toggle('bd-toc-list--collapsed', isOpen);
        tocToggle.querySelector('i').className = isOpen ? 'fa-solid fa-chevron-down' : 'fa-solid fa-chevron-up';
      });
    }

    /* ---- Copy link ---- */
    function copyLink() {
      navigator.clipboard.writeText(window.location.href).then(function () {
        var tip = document.createElement('div');
        tip.className = 'bd-copy-toast';
        tip.textContent = 'Link copied!';
        document.body.appendChild(tip);
        setTimeout(function () { tip.classList.add('bd-copy-toast--show'); }, 10);
        setTimeout(function () { tip.remove(); }, 2200);
      });
    }
    var cpBtn = document.getElementById('bdCopyLink');
    var cpBtnM = document.getElementById('bdCopyLinkMobile');
    if (cpBtn) cpBtn.addEventListener('click', function (e) { e.preventDefault(); copyLink(); });
    if (cpBtnM) cpBtnM.addEventListener('click', function (e) { e.preventDefault(); copyLink(); });

    /* ---- Bookmark toggle ---- */
    var bmBtn = document.getElementById('bdBookmark');
    if (bmBtn) {
      bmBtn.addEventListener('click', function () {
        var icon = bmBtn.querySelector('i');
        var saved = icon.classList.contains('fa-solid');
        icon.className = saved ? 'fa-regular fa-bookmark' : 'fa-solid fa-bookmark';
      });
    }

    /* ---- Newsletter form ---- */
    var nlForm = document.getElementById('bdsNlForm');
    var nlMsg = document.getElementById('bdsNlMsg');
    if (nlForm) {
      nlForm.addEventListener('submit', function (e) {
        e.preventDefault();
        /* DYNAMIC: POST to /api/newsletter */
        nlMsg.textContent = 'Thanks! You\'re subscribed.';
        nlMsg.style.color = '#22c55e';
        nlForm.reset();
      });
    }

  })();
  </script>
