<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= page.title %></title>
  <meta name="description" content="<%= page.metaDesc %>"/>
  <meta name="robots" content="index, follow"/>
  <link rel="canonical" href="https://www.kreditseva.com/loan/<%= page.slug %>"/>

  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link rel="stylesheet" href="/css/global.css"/>
  <link rel="stylesheet" href="/css/theme.css"/>
  <link rel="stylesheet" href="/css/personal-loan.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,400;0,500;0,600;0,700;1,700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/loader.css"/>
  <link rel="stylesheet" href="/css/homepage.css" />
  <meta name="robots" content="index, follow" />
</head>
<body>

  <!-- PAGE LOADER -->
  <div id="ks-loader">
    <div class="ks-loader-bar-wrap"><div class="ks-loader-bar"></div></div>
    <div class="ks-loader-logo">Kredit<span>Seva</span><small>.com</small></div>
    <p class="ks-loader-tag">A Brand of Voice Technologies and Business Solutions</p>
    <div class="ks-loader-dots"><span></span><span></span><span></span></div>
  </div>

  <!-- HEADER -->
  <div class="site-header-wrap">
    <div class="top-strip">
      <div class="top-strip-inner">
        <a href="/become-our-partner" class="top-strip-link" style="font-size:14px;">
          <i class="fa-solid fa-handshake" style="color:#D2956A;font-size:18px;"></i> Become Our Partner
        </a>
        <a href="/check-my-credit-score" class="top-strip-link" style="font-size:14px;">
          <i class="fa-solid fa-chart-simple" style="color:#4ade80;font-size:18px;"></i> Check Your Credit Score
        </a>
        <a href="https://wa.me/919990033593" class="top-strip-link" target="_blank" rel="noopener" style="font-size:14px;">
          <i class="fa-brands fa-whatsapp" style="color:#fff;background:#25D366;border-radius:50%;padding:3px;font-size:18px;width:26px;height:26px;display:inline-flex;align-items:center;justify-content:center;"></i> +91-999-0033-593
        </a>
      </div>
    </div>
    <header class="main-header">
      <div class="navbar">
        <a href="/" class="brand-logo">Kredit<span>Seva</span><small class="brand-dotcom">.com</small></a>
        <button class="menu-btn" id="menuBtn">☰</button>
        <nav class="nav-links" id="navLinks">
          <a href="/" class="simple-link">Home</a>
          <div class="nav-dropdown">
            <a href="javascript:void(0)">Personal Loan <svg class="nav-arrow" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <div class="dropdown-menu">
              <a href="/personal-loan">Personal Loan</a>
              <a href="/personal-overdraft">Personal Overdraft</a>
              <a href="/balance-transfer">Balance Transfer</a>
              <a href="/debt-consolidation">Debt Consolidation</a>
              <a href="/insta-loan">Insta Loan</a>
            </div>
          </div>
          <div class="nav-dropdown">
            <a href="javascript:void(0)">Business Loan <svg class="nav-arrow" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <div class="dropdown-menu">
              <a href="/business-loan">Business Loan</a>
              <a href="/working-capital">Working Capital</a>
              <a href="/unsecured-business-loan">Unsecured Business Loan</a>
              <a href="/business-overdraft">Business Overdraft</a>
            </div>
          </div>
          <div class="nav-dropdown">
            <a href="javascript:void(0)">Professional Loan <svg class="nav-arrow" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <div class="dropdown-menu">
              <a href="/professional-loan">Professional Loan</a>
              <a href="/loan-for-ca">Loan For CA</a>
              <a href="/loan-for-cs">Loan For CS</a>
              <a href="/loan-for-doctor">Loan For Doctors</a>
            </div>
          </div>
          <div class="nav-dropdown">
            <a href="javascript:void(0)">Secured Loan <svg class="nav-arrow" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <div class="dropdown-menu">
              <a href="/secured-loan">Secured Loan</a>
              <a href="/loan-against-property">Loan Against Property</a>
              <a href="/home-loan">Home Loan</a>
              <a href="/car-loan">Car Loan</a>
            </div>
          </div>
          <a href="/credit-card" class="simple-link">Credit Cards</a>
          <div class="nav-dropdown">
            <a href="javascript:void(0)">Tools
              <svg class="nav-arrow" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <div class="dropdown-menu">
              <a href="/personal-loan#lec-calculator">Loan Eligibility Calculator</a>
<a href="/debt-consolidation#emi-calculator">Debt Consolidation Calculator</a>
<a href="/balance-transfer#emi-calculator">Balance Transfer Savings Calculator</a>
<a href="/personal-loan#emi-calculator">Personal Loan EMI Calculator</a>
<a href="/personal-overdraft#od-calc">Overdraft Interest Calculator</a>
<a href="/business-loan#emi-calculator">Business Loan EMI Calculator</a>
<a href="/secured-loan#emi-calculator">Secured Loan EMI Calculator</a>
<a href="/professional-loan#emi-calculator">Professional Loan EMI Calculator</a>
            </div>
          </div>
          <a href="/become-our-partner" class="mobile-apply-btn" style="background:rgba(56,189,248,0.15);border-color:#38BDF8;color:#38BDF8;">Become a Partner</a>
          <a href="/apply-now" class="mobile-apply-btn">Apply Now</a>
        </nav>
        <a href="/apply-now" class="desktop-apply-btn">Apply Now</a>
      </div>
    </header>
  </div>

  <!-- HERO -->
  <section class="pl-hero" data-animate>
    <div class="pl-hero-wave-top">
      <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0,40 C360,0 1080,80 1440,40 L1440,0 L0,0 Z" fill="rgba(26,82,204,0.10)"/>
        <path d="M0,25 C480,70 960,10 1440,25 L1440,0 L0,0 Z" fill="rgba(56,189,248,0.14)"/>
      </svg>
    </div>
    <div class="pl-hero-wave">
      <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="rgba(26,82,204,0.10)"/>
        <path d="M0,55 C480,10 960,70 1440,55 L1440,80 L0,80 Z" fill="rgba(56,189,248,0.14)"/>
      </svg>
    </div>
    <div class="pl-hero-inner">
      <div class="pl-hero-copy">
        <span class="pl-hero-pill"><span class="pl-hero-dot"></span> <%= page.cityName %>, <%= page.state %></span>
        <h1 class="pl-hero-h1">
          <span class="pl-hero-accent"><%= page.loanName %> in <%= page.cityName %></span><br>
          Starting @ <%= page.rate %>% p.a.
        </h1>
        <p class="pl-hero-sub"><%= page.heroDesc %></p>
        <div class="pl-hero-checks">
          <div class="pl-hero-check"><span class="pl-chk">✓</span> Up to <%= page.maxAmount %></div>
          <div class="pl-hero-check"><span class="pl-chk">✓</span> Rate from <%= page.rate %>% p.a.</div>
          <div class="pl-hero-check"><span class="pl-chk">✓</span> No Collateral Required</div>
          <div class="pl-hero-check"><span class="pl-chk">✓</span> 100% Paperless Process</div>
        </div>
        <div class="pl-hero-actions">
          <a href="/apply-now?product=<%= page.slug %>" class="pl-btn-primary btn-wave">
            Apply Now — It's Free
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
      <div class="pl-hero-form">
        <div class="pl-form-header">
          <h3><%= page.loanName %> in <%= page.cityName %></h3>
          <p>Free · No hidden charges · Instant callback</p>
        </div>
        <form class="pl-form" onsubmit="return false;">
          <div class="pl-form-field">
            <label>Mobile Number</label>
            <div class="pl-phone-wrap">
              <span class="pl-phone-code"><i class="fa-solid fa-phone"></i> +91</span>
              <input type="tel" id="heroPhone" placeholder="Enter mobile number" maxlength="10"/>
            </div>
            <span class="pl-field-err" id="err-heroPhone"></span>
          </div>
          <button id="btn-submit" type="submit" class="pl-form-btn" onclick="redirect('<%= page.loanKey %>-<%= page.cityKey %>')">
            Proceed — Check Eligibility
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
          <p class="pl-form-note"><i class="fa-solid fa-lock"></i> Your data is safe & 100% confidential</p>
        </form>
      </div>
    </div>
  </section>

  <!-- WHAT IS -->
  <section class="pl-what-section" data-animate>
    <div class="pl-what-wrap">
      <div class="pl-what-left">
        <h2><%= page.loanName %> in <%= page.cityName %> — <span>Everything You Need to Know</span></h2>
        <p><%= page.whatDesc1 %></p>
        <p><%= page.whatDesc2 %></p>
        <div class="pl-what-actions">
          <a href="/apply-now?product=<%= page.slug %>" class="pl-what-btn-primary">Apply Now — Free</a>
          <a href="/check-my-credit-score" class="pl-what-btn-secondary">Check Credit Score</a>
        </div>
      </div>
      <div class="pl-what-right">
        <div class="pl-what-card">
          <div class="pl-what-icon" style="background:rgba(0,212,255,0.1);color:#00a8d6;"><i class="fa-solid fa-indian-rupee-sign" style="font-size:1.2rem;"></i></div>
          <div><h4>Up to <%= page.maxAmount %></h4><p>Get the loan amount you need in <%= page.cityName %>.</p></div>
        </div>
        <div class="pl-what-card">
          <div class="pl-what-icon" style="background:rgba(74,222,128,0.1);color:#22a85a;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><polyline points="20 6 9 17 4 12"/></svg></div>
          <div><h4>Rate from <%= page.rate %>% p.a.</h4><p>Lowest rates from 25+ lenders in <%= page.cityName %>.</p></div>
        </div>
        <div class="pl-what-card">
          <div class="pl-what-icon" style="background:rgba(255,185,71,0.1);color:#c47e00;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
          <div><h4>Quick Approval</h4><p>Fast digital process — disbursal within 24–48 hrs.</p></div>
        </div>
        <div class="pl-what-card">
          <div class="pl-what-icon" style="background:rgba(139,109,255,0.1);color:#6c4edb;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
          <div><h4>25+ Lenders</h4><p>Compare all top banks & NBFCs serving <%= page.cityName %>.</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- EMI CALCULATOR -->
  <section class="emi-section" data-animate id="emi-calculator">
    <div class="emi-wrap">
      <div class="emi-head">
        <span class="emi-eyebrow">EMI CALCULATOR</span>
        <h2><%= page.loanName %> in <%= page.cityName %> — <span>EMI Calculator</span></h2>
        <p>Calculate your monthly EMI and plan your repayment easily.</p>
      </div>
      <div class="emi-card">
        <div class="emi-left">
          <h3>Loan Break-up</h3>
          <div class="emi-donut-wrap">
            <canvas id="emiPieChart"></canvas>
            <div class="emi-donut-center">
              <span class="emi-donut-label">Total</span>
              <strong id="emiDonutTotal">₹ 0</strong>
            </div>
          </div>
          <div class="emi-legend">
            <div class="emi-leg-item"><span class="emi-leg-dot" style="background:#1a52cc;"></span><span>Principal Amount</span></div>
            <div class="emi-leg-item"><span class="emi-leg-dot" style="background:#00cfff;"></span><span>Total Interest</span></div>
          </div>
        </div>
        <div class="emi-right">
          <div class="emi-field">
            <div class="emi-field-head"><label>Loan Amount</label><div class="emi-val-box"><span class="emi-prefix">₹</span><input type="number" id="loanAmount" value="1000000"></div></div>
            <input type="range" id="loanRange" min="50000" max="5000000" step="50000" value="1000000">
            <div class="emi-range-labels"><span>₹50K</span><span>₹50L</span></div>
          </div>
          <div class="emi-field">
            <div class="emi-field-head"><label>Rate of Interest</label><div class="emi-val-box"><input type="number" id="interestRate" value="<%= page.rate %>"><span class="emi-suffix">%</span></div></div>
            <input type="range" id="rateRange" min="1" max="30" step="0.5" value="<%= page.rate %>">
            <div class="emi-range-labels"><span>1%</span><span>30%</span></div>
          </div>
          <div class="emi-field">
            <div class="emi-field-head"><label>Loan Tenure</label><div class="emi-val-box emi-tenure-box"><input type="number" id="loanTenure" value="3"><div class="emi-tenure-toggle"><button type="button" class="active" data-unit="years">Yr</button><button type="button" data-unit="months">Mo</button></div></div></div>
            <input type="range" id="tenureRange" min="1" max="10" step="1" value="3">
            <div class="emi-range-labels"><span>1 Yr</span><span>10 Yr</span></div>
          </div>
          <div class="emi-results-row">
            <div class="emi-res-item emi-res-highlight"><span>Monthly EMI</span><strong id="monthlyEmi">₹ 0</strong></div>
            <div class="emi-res-item"><span>Principal</span><strong id="principalAmount">₹ 0</strong></div>
            <div class="emi-res-item"><span>Total Interest</span><strong id="totalInterest">₹ 0</strong></div>
            <div class="emi-res-item"><span>Total Payable</span><strong id="totalPayable">₹ 0</strong></div>
          </div>
          <a href="/apply-now?product=<%= page.slug %>" class="emi-apply-btn">
            Apply Now
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <p class="emi-disclaimer"><i class="fas fa-shield-alt"></i> Indicative values only. Actual EMI may vary based on lender terms.</p>
        </div>
      </div>
    </div>
  </section>
  <!-- CREDIT SCORE BANNER -->
  <section class="plx-credit">
    <div class="plx-credit-card">
      <div class="plx-orb plx-orb-credit-1"></div>
      <div class="plx-orb plx-orb-credit-2"></div>
      <div class="plx-credit-grid"><div class="plx-credit-grid-inner"></div></div>
      <div class="plx-credit-left">
        <h2>Check your <span class="plx-h-accent">Credit Score</span> &mdash; free</h2>
        <p>Instant score check, zero impact on your credit &mdash; unlock pre-approved offers from 25+ lenders.</p>
        <a href="/check-my-credit-score" class="plx-credit-cta">Check My Credit Score <span class="plx-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span></a>
        <ul class="plx-credit-bullets">
          <li><span class="plx-tick">&#10003;</span> 100% Free</li>
          <li><span class="plx-tick">&#10003;</span> Zero score impact</li>
          <li><span class="plx-tick">&#10003;</span> Pre-approved offers</li>
        </ul>
      </div>
      <div class="plx-credit-right">
        <object type="image/svg+xml" data="/images/credit-gauge.svg" class="plx-credit-gauge"></object>
        <div class="plx-credit-floater plx-credit-float-1"><div class="ficon green"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><div><div class="label">Score Range</div><div class="value">725+ Excellent</div></div></div>
        <div class="plx-credit-floater plx-credit-float-2"><div class="ficon cyan"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div><div><div class="label">Unlock</div><div class="value">Pre-approved offers</div></div></div>
      </div>
    </div>
  </section>


  <!-- ELIGIBILITY -->
  <section class="pl-elig-section" data-animate>
    <div class="pl-elig-wrap">
      <div class="pl-elig-head">
        <span class="pl-elig-eyebrow">LOAN REQUIREMENTS</span>
        <h2>Eligibility & <span>Required Documents</span></h2>
      </div>
      <div class="pl-elig-grid">
        <div class="pl-elig-card pl-elig-left">
          <div class="pl-elig-card-head">
            <div class="pl-elig-card-icon" style="background:rgba(26,82,204,0.1);color:#1a52cc;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
            <div><h3>Eligibility Criteria</h3><p>To qualify for <%= page.loanName %> in <%= page.cityName %></p></div>
          </div>
          <div class="pl-elig-items">
            <div class="pl-elig-item"><div class="pl-elig-item-icon" style="background:rgba(0,207,255,0.1);color:#00a8d6;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div><div><span>Age</span><strong>21 to 60 years</strong></div></div>
            <div class="pl-elig-item"><div class="pl-elig-item-icon" style="background:rgba(74,222,128,0.1);color:#22a85a;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><rect x="2" y="5" width="20" height="14" rx="3"/><path d="M2 10h20"/></svg></div><div><span>Monthly Income</span><strong><%= page.minIncome %>+</strong></div></div>
            <div class="pl-elig-item"><div class="pl-elig-item-icon" style="background:rgba(255,185,71,0.1);color:#c47e00;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div><div><span>Credit Score</span><strong>625+ preferred</strong></div></div>
            <div class="pl-elig-item"><div class="pl-elig-item-icon" style="background:rgba(139,109,255,0.1);color:#6c4edb;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-4 0v2"/></svg></div><div><span>Employment</span><strong>Salaried / Self-employed</strong></div></div>
          </div>
        </div>
        <div class="pl-elig-card pl-elig-right">
          <div class="pl-elig-card-head">
            <div class="pl-elig-card-icon" style="background:rgba(0,207,255,0.1);color:#00a8d6;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
            <div><h3>Required Documents</h3><p>Minimal docs for fast approval</p></div>
          </div>
          <div class="pl-elig-items">
            <div class="pl-elig-item"><div class="pl-elig-item-icon" style="background:rgba(0,207,255,0.1);color:#00a8d6;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M8 2v4M16 2v4M3 10h18"/></svg></div><div><span>KYC</span><strong>Aadhaar / PAN Card</strong></div></div>
