    <svg viewBox="0 0 24 24" class="scroll-icon"><path d="M12 19V6"/><path d="M6 12L12 6L18 12"/></svg>
  </button>
  <a href="https://wa.me/919138130188" target="_blank" rel="noopener" class="whatsapp-float">
    <i class="fa-brands fa-whatsapp"></i>
