            <span>+91-99900-33593</span>
          </a>
          <a href="https://wa.me/919990033593" class="footer-contact-row" target="_blank" rel="noopener">
            <div class="footer-contact-icon fci-wa"><i class="fa-brands fa-whatsapp"></i></div>
