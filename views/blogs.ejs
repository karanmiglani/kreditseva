      <!-- RIGHT: Address cards -->
      <div class="footer-right">
        <h4 class="footer-contact-heading">Contact Information</h4>
        <div class="footer-address-cards">
          <div class="footer-address-card">
            <i class="fa-solid fa-location-dot"></i>
            <div>
              <h5>KreditSeva (Voice Technologies &amp; Business Solutions)</h5>
              <p>New Delhi, India</p>
            </div>
          </div>
          <div class="footer-address-card">
            <i class="fa-solid fa-clock"></i>
            <div>
              <h5>Working Hours</h5>
              <p>Monday to Saturday &mdash; 9:00 AM to 7:00 PM</p>
            </div>
          </div>
          <div class="footer-address-card">
            <i class="fa-solid fa-shield-halved"></i>
            <div>
              <h5>Registered DSA Partner</h5>
              <p>Partnered with 45+ banks and NBFCs across India for personal, business, professional and secured loans.</p>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom link bar -->
    <div class="footer-bottom">
      <div class="footer-bottom-inner">
        <div class="footer-bottom-links">
          <a href="/about-us">About Us</a>
          <a href="/our-team">Our Team</a>
          <a href="/contact-us">Contact Us</a>
          <a href="/blogs">Blogs</a>
