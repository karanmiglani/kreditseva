  <!-- =====================================================
    BLOG HERO BANNER
  ====================================================== -->
  <section class="bl-hero" data-animate>
    <!-- Decorative shapes -->
    <div class="bl-shape bl-shape-1"></div>
    <div class="bl-shape bl-shape-2"></div>
    <div class="bl-shape bl-shape-3"></div>
    <div class="bl-shape bl-shape-4"></div>
    <div class="bl-hero-inner">
      <p class="bl-hero-eyebrow"><i class="fa-solid fa-pen-nib"></i> KreditSeva Blog</p>
      <h1>Financial Tips, Loan Guides<br>&amp; Expert Insights</h1>
      <p class="bl-hero-sub">Stay informed with expert articles on personal finance, loan strategies, and credit health.</p>
    </div>
  </section>


  <!-- =====================================================
    CATEGORY FILTER TABS
    DYNAMIC: Active tab highlighted based on ?cat= query param
    Backend: GET /blogs?cat=personal-loan  OR  /api/blogs?cat=personal-loan
  ====================================================== -->
  <div class="bl-filter-wrap">
    <div class="bl-filter-inner">
      <div class="bl-tabs" id="blTabs">
        <!-- DYNAMIC: loop categories from backend, add class="active" to current -->
        <button class="bl-tab active" data-cat="all">All</button>
        <button class="bl-tab" data-cat="personal-loan">Personal Loan</button>
        <button class="bl-tab" data-cat="business-loan">Business Loan</button>
        <button class="bl-tab" data-cat="professional-loan">Professional Loan</button>
        <button class="bl-tab" data-cat="secured-loan">Secured Loan</button>
        <button class="bl-tab" data-cat="credit-score">Credit Score</button>
        <button class="bl-tab" data-cat="investment">Investment</button>
        <!-- END DYNAMIC -->
      </div>
    </div>
  </div>


  <!-- =====================================================
    MAIN CONTENT AREA
  ====================================================== -->
  <main class="bl-main">
    <div class="bl-layout" data-animate>

      <!-- ================================================
        LEFT: POSTS
      ================================================= -->
      <div class="bl-posts-col">
        <% if(fb.length > 0){ %>
        <!-- DYNAMIC: show only if featured_post exists -->
        <a href="/blog-detail" class="bl-featured" id="blFeatured">
          <!-- DYNAMIC: featured_post.image -->
          <div class="bl-featured-img" data-animate>
            <img src="<%= fb.featured_image %>" alt="Types of Debt Funds" />
            <span class="bl-feat-badge"><i class="fa-solid fa-fire"></i> Featured</span>
          </div>
          <div class="bl-featured-body" data-animate>
            <!-- DYNAMIC: featured_post.category -->
            <span class="blc-badge blc-personal"><%= fb.category %></span>
            <!-- DYNAMIC: featured_post.title -->
            <h2><%= fb.title %></h2>
            <!-- DYNAMIC: featured_post.excerpt -->
            <p><%= fb.meta_desc %></p>
            <div class="bl-feat-meta">
              <!-- DYNAMIC: featured_post.author_name, featured_post.published_date, featured_post.read_time -->
              <span><i class="fa-regular fa-user"></i> KreditSeva Team</span>
              <span><i class="fa-regular fa-calendar"></i> Jan 15, 2026</span>
              <span><i class="fa-regular fa-clock"></i> <%= fb.read_time %> mins</span>
            </div>
          </div>
        </a>
        <% } %>
        <!-- END DYNAMIC featured -->


        <!-- -----------------------------------------------
          POSTS GRID
          DYNAMIC: Loop posts[] from backend
          Each card = one blog post
          JS replaces this section on filter/search/pagination
        ----------------------------------------------- -->
        <div class="bl-grid" id="blGrid" data-animate>

          <!-- ---- CARD 1 ---- -->
          <!-- DYNAMIC: posts[0] -->
<% if (blogs.length > 0) { %>

  <% blogs.forEach((blog, index) => { %>

    <a href="blog/<%= blog.slug %>" class="bl-card" data-cat="<%= blog.category %>">
      
      <div class="bl-card-img">
        <img src="<%= blog.featured_image %>" alt="MSME Loan Tips" />

        <span class="blc-badge blc-business">
          <%= blog.category
              ? blog.category
                  .split('-')
                  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
                  .join(' ')
              : ""
          %>
        </span>
      </div>

      <div class="bl-card-body">
        <h3><%= blog.title %></h3>

        <p><%= blog.meta_desc %></p>

        <div class="bl-card-meta">
          <span>
            <i class="fa-regular fa-calendar"></i>
            <%= new Date(blog.created_at).toLocaleDateString() %>
          </span>

          <span>
            <i class="fa-regular fa-clock"></i>
            <%= blog.read_time %> min
          </span>
        </div>
      </div>

    </a>

  <% }) %>

<% } %>
        </div>
        <!-- END DYNAMIC blGrid -->


        <!-- -----------------------------------------------
          SKELETON LOADERS — shown during JS fetch
          JS adds class "bl-loading" to bl-posts-col to show these
        ----------------------------------------------- -->
        <div class="bl-skeletons" id="blSkeletons">
          <div class="bl-skel-card"><div class="bl-skel-img"></div><div class="bl-skel-line w80"></div><div class="bl-skel-line w60"></div><div class="bl-skel-line w40"></div></div>
          <div class="bl-skel-card"><div class="bl-skel-img"></div><div class="bl-skel-line w80"></div><div class="bl-skel-line w60"></div><div class="bl-skel-line w40"></div></div>
          <div class="bl-skel-card"><div class="bl-skel-img"></div><div class="bl-skel-line w80"></div><div class="bl-skel-line w60"></div><div class="bl-skel-line w40"></div></div>
        </div>


        <!-- -----------------------------------------------
          LOAD MORE BUTTON
          DYNAMIC: JS sends GET /api/blogs?page=2&cat=X
          Hide when no more posts (backend returns has_more: false)
        ----------------------------------------------- -->
        <div class="bl-load-wrap">
          <!-- DYNAMIC: hide if total_posts <= per_page -->
          <button class="bl-load-btn" id="blLoadMore" data-page="1" data-cat="all">
            <span id="blLoadText">Load More Articles</span>
            <span id="blLoadSpinner" class="bl-spinner" style="display:none;"></span>
          </button>
          <!-- DYNAMIC: show when all posts loaded -->
          <p class="bl-no-more" id="blNoMore" style="display:none;">You've read everything! <a href="#">Back to top ↑</a></p>
        </div>

      </div>
      <!-- END posts col -->


      <!-- ================================================
        RIGHT: SIDEBAR
      ================================================= -->
      <aside class="bl-sidebar">

        <!-- CTA -->
        <div class="bls-cta">
          <div class="bls-cta-icon"><i class="fa-solid fa-indian-rupee-sign"></i></div>
          <h4>Need a Loan?</h4>
          <p>Get instant approval on personal &amp; business loans at best rates.</p>
          <a href="/apply-now" class="bls-cta-btn">Apply Now <i class="fa-solid fa-arrow-right"></i></a>
        </div>

        <!-- Credit Score CTA -->
        <div class="bls-score">
          <i class="fa-solid fa-star bls-score-icon"></i>
          <h4>Free Credit Score Check</h4>
          <p>Zero impact on your score. Instant results.</p>
          <a href="/check-my-credit-score" class="bls-score-btn">Check Now — It's Free</a>
        </div>

      </aside>

    </div>
  </main>


