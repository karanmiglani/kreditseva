# Server
NODE_ENV=production
PORT=3000

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL=false
# Auth — use a long random string; no quotes or leading spaces
JWT_SECRET_KEY=

# Optional: extra CORS origins, comma-separated
# CORS_ORIGIN=https://staging.kreditseva.com

# Optional: bump on deploy to bust browser cache for CSS/JS (auto-set on restart if omitted)
# ASSET_VERSION=20250624
