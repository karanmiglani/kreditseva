# Server
NODE_ENV=production
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
# Set to true for managed MySQL with SSL (e.g. PlanetScale, AWS RDS)
DB_SSL=false

# Set to true temporarily to log DB config in server logs (masked password)
# DEBUG_DB=true
# DEBUG_DB_FULL=true   # logs full password — remove immediately after debugging


# Auth — use a long random string; no quotes or leading spaces
JWT_SECRET_KEY=

# Optional: extra CORS origins, comma-separated
# CORS_ORIGIN=https://staging.kreditseva.com
