# Server
NODE_ENV=production
PORT=3000

# Database (from hPanel → Databases → MySQL — copy EXACT values)
DB_HOST=localhost
DB_PORT=3306
DB_USER=u123456789_youruser
DB_PASSWORD=your_hpanel_password
DB_NAME=u123456789_kredit_seva
# If localhost fails, try: DB_HOST=127.0.0.1
# Optional socket path on some Hostinger servers:
# DB_SOCKET=/var/run/mysqld/mysqld.sock
DB_SSL=false

# Set to true temporarily to log DB config in server logs (masked password)
# DEBUG_DB=true
# DEBUG_DB_FULL=true   # logs full password — remove immediately after debugging


# Auth — use a long random string; no quotes or leading spaces
JWT_SECRET_KEY=

# Optional: extra CORS origins, comma-separated
# CORS_ORIGIN=https://staging.kreditseva.com
